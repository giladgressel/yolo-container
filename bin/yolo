#!/usr/bin/env bash
# yolo — run Claude Code in a YOLO container mounted on $PWD.
#
# One shared image (yolo-claude:latest) built from this repo's .devcontainer/
# dir (located automatically relative to this script, so it works when invoked
# via a symlink in ~/.local/bin). Bind-mounts $PWD to /workspace. Container's
# .venv is an anonymous volume so it never collides with the host's macOS .venv.
# uv cache is a shared named volume.
#
# Host Claude config (CLAUDE.md, settings, skills, statusline) is mounted
# READ-ONLY so the sandbox can read your preferences but can't modify them.
# Changes made inside the container stay inside. To push a change back to the
# host, copy it out manually (the "over-the-wall" flow).
#
# Requires OrbStack (or any Docker) running. Stock macOS ssh-agent forwarded via
# OrbStack's /run/host-services/ssh-auth.sock.

set -euo pipefail

IMAGE="yolo-claude:latest"

# Resolve this script's real location (follows symlinks, so ~/.local/bin/yolo
# can symlink into the repo). CTX is the .devcontainer dir next to bin/.
SCRIPT="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
REPO_DIR="$(cd -P "$(dirname "$SCRIPT")/.." && pwd)"
CTX="$REPO_DIR/.devcontainer"

if ! command -v docker >/dev/null 2>&1; then
  echo "yolo: docker CLI not found. Install OrbStack: brew install orbstack" >&2
  exit 1
fi

if ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "yolo: building $IMAGE (first run — a few minutes)..." >&2
  docker build --build-arg "HOST_USERNAME=$(whoami)" -t "$IMAGE" "$CTX"
fi

args=(
  --rm -it
  --cap-add=NET_ADMIN --cap-add=NET_RAW
  --memory=8g --cpus=4
  -v "$PWD:/workspace" -w /workspace
  -v /workspace/.venv
  -v yolo-uv-cache:/home/node/.cache/uv
  -v yolo-uv-data:/home/node/.local/share/uv
  -v yolo-claude-config:/home/node/.claude
  -v yolo-bashhistory:/commandhistory
  -v /run/host-services/ssh-auth.sock:/ssh-agent
  -e SSH_AUTH_SOCK=/ssh-agent
  -e CLAUDE_CONFIG_DIR=/home/node/.claude
)

# Git worktree support. In a linked worktree (Orca, `git worktree add`, …) the
# .git inside $PWD is a FILE pointing at .git/worktrees/<name> in the main repo,
# which lives outside the $PWD bind mount. Without this, every `git` command in
# the container fails because the gitdir pointer doesn't resolve.
#
# Fix: locate the main repo's .git via the worktree's commondir, then mount it
# at the same host path inside the container. The worktree's per-branch dir
# (.git/worktrees/<name>) is a child of that, so one mount covers both.
if [ -f "$PWD/.git" ]; then
  worktree_gitdir=$(sed -n 's/^gitdir: //p' "$PWD/.git" 2>/dev/null || true)
  if [ -n "$worktree_gitdir" ] && [ -d "$worktree_gitdir" ] && [ -f "$worktree_gitdir/commondir" ]; then
    commondir_raw=$(cat "$worktree_gitdir/commondir")
    if [ "${commondir_raw:0:1}" = "/" ]; then
      main_gitdir="$commondir_raw"
    else
      main_gitdir=$(cd -P "$worktree_gitdir/$commondir_raw" 2>/dev/null && pwd || true)
    fi
    if [ -n "$main_gitdir" ] && [ -d "$main_gitdir" ]; then
      args+=(-v "$main_gitdir:$main_gitdir")
      echo "yolo: linked worktree detected — mounting $main_gitdir for git access" >&2
    else
      echo "yolo: warning — couldn't resolve main .git from worktree (commondir=$commondir_raw); git will be broken in container" >&2
    fi
  fi
fi

# Host config read-only (CLAUDE.md, settings, skills, statusline, starship, netrc, gitconfig)
# Each mount is conditional on the host file existing — missing files are skipped
# with a one-line notice so a typo'd path doesn't fail silently. Return 0
# unconditionally so a missing source file under `set -e` doesn't kill the script.
add_ro() {
  if [ -e "$1" ]; then
    args+=(-v "$1:$2:ro")
  else
    echo "yolo: skipping mount (not found): $1" >&2
  fi
}
add_ro_first() {
  # First candidate that exists wins; lets us prefer standard paths and fall back to dotfiles layouts.
  local target="$1"; shift
  for candidate in "$@"; do
    if [ -e "$candidate" ]; then
      args+=(-v "$candidate:$target:ro")
      return 0
    fi
  done
  echo "yolo: skipping mount -> $target (no candidate found: $*)" >&2
  return 0
}
add_ro "$HOME/.claude/CLAUDE.md"             /home/node/.claude/CLAUDE.md
add_ro "$HOME/.claude/settings.json"         /home/node/.claude/settings.json
add_ro "$HOME/.claude/settings.local.json"   /home/node/.claude/settings.local.json
add_ro "$HOME/.claude/skills"                /home/node/.claude/skills
add_ro "$HOME/.agents/skills"                /home/node/.agents/skills
add_ro "$HOME/.claude/statusline-command.sh" /home/node/.claude/statusline-command.sh
add_ro "$HOME/.claude.json"                  /yolo/host-claude.json
add_ro_first                                 /home/node/.config/starship.toml \
  "$HOME/.config/starship.toml" \
  "$HOME/.dotfiles/starship.toml"
add_ro "$HOME/.netrc"                        /home/node/.netrc
add_ro "$HOME/.gitconfig"                    /home/node/.gitconfig

# Forward WANDB_API_KEY so the wandb HTTP MCP can authenticate
if [ -n "${WANDB_API_KEY:-}" ]; then
  args+=(-e WANDB_API_KEY)
fi

# Forward ANTHROPIC_API_KEY if set (optional — otherwise use `claude` interactive login)
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  args+=(-e ANTHROPIC_API_KEY)
fi

# Forward GH_TOKEN so gh CLI is pre-authenticated inside the container
if [ -n "${GH_TOKEN:-}" ]; then
  args+=(-e GH_TOKEN)
fi

# Forward ORCA_WORKTREE_ID so Claude inside the container knows it's in an
# Orca-managed worktree (drives the Delete/Sleep guidance in CLAUDE.md). Other
# ORCA_* vars are skipped: they reference host-only paths or a hook port that
# isn't reachable from the container without extra networking plumbing.
if [ -n "${ORCA_WORKTREE_ID:-}" ]; then
  args+=(-e ORCA_WORKTREE_ID)
fi

exec docker run "${args[@]}" "$IMAGE" \
  bash -lc '
    set -e

    # Firewall
    sudo /usr/local/bin/init-firewall.sh

    # (/Users/$HOST_USERNAME/.claude -> /home/node/.claude symlink is baked into image)

    # Sync mcpServers from host ~/.claude.json into container config.
    # CLAUDE_CONFIG_DIR redirects where the CLI reads/writes .claude.json, so
    # we must honor it — default $HOME/.claude.json is wrong when the env var is set.
    if [ -f /yolo/host-claude.json ]; then
      target="${CLAUDE_CONFIG_DIR:-$HOME}/.claude.json"
      host_mcps=$(jq -c ".mcpServers // {}" /yolo/host-claude.json 2>/dev/null || echo "{}")
      if [ -f "$target" ]; then
        jq --argjson m "$host_mcps" ".mcpServers = \$m" "$target" > "$target.tmp" && mv "$target.tmp" "$target"
      else
        echo "{\"mcpServers\": $host_mcps}" | jq . > "$target"
      fi
      count=$(echo "$host_mcps" | jq "keys | length")
      echo "yolo: synced $count MCP server(s) from host -> $target"
    fi

    # Python project: sync deps into container-local .venv (anonymous volume)
    if [ -f pyproject.toml ] && [ ! -x .venv/bin/python ]; then
      echo "yolo: running uv sync..."
      uv sync
    fi

    exec zsh
  '
