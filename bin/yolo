#!/usr/bin/env bash
# yolo — run Claude Code in a YOLO container mounted on $PWD.
#
# SLURM/podman variant. Intended to be run either on a cluster login node or
# on a compute node you've SSH'd into via an interactive SLURM allocation
# (e.g. the rtx6000pro_golden.sh sleep-job trick — `sbatch` a node, then
# `ssh` into it and work there).
#
# One shared image (yolo-claude:latest) built from this repo's .devcontainer/
# dir. Bind-mounts $PWD to /workspace. Container's .venv is an anonymous
# volume so it never collides with the host's .venv (glibc/ABI mismatch
# between RHEL9 host and Debian container). uv cache is a shared named
# volume.
#
# Host Claude config (CLAUDE.md, settings, skills, statusline) is mounted
# READ-ONLY. Changes made inside the container stay inside. To push a change
# back to the host, copy it out manually (the "over-the-wall" flow).
#
# GPU passthrough is auto-detected: if CDI is configured, uses
# `--device nvidia.com/gpu=all`; else if /dev/nvidiactl exists, bind-mounts
# the nvidia device nodes and driver userspace libs. On the login node
# (no GPU) it silently skips.

set -euo pipefail

IMAGE="yolo-claude:latest"
ENGINE="${YOLO_ENGINE:-podman}"

# Resolve this script's real location (follows symlinks, so ~/.local/bin/yolo
# can symlink into the repo). CTX is the .devcontainer dir next to bin/.
SCRIPT="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$SCRIPT_DIR/$SCRIPT"
done
REPO_DIR="$(cd -P "$(dirname "$SCRIPT")/.." && pwd)"
CTX="$REPO_DIR/.devcontainer"

if ! command -v "$ENGINE" >/dev/null 2>&1; then
  echo "yolo: $ENGINE CLI not found. Set YOLO_ENGINE=docker if you have docker instead." >&2
  exit 1
fi

if ! "$ENGINE" image inspect "$IMAGE" >/dev/null 2>&1; then
  echo "yolo: building $IMAGE (first run — a few minutes)..." >&2
  "$ENGINE" build -t "$IMAGE" "$CTX"
fi

args=(
  --rm -it
  # SELinux: disable label enforcement for bind mounts. On RHEL9 the safer
  # `:z` / `:Z` suffixes relabel source files, which we don't want for
  # shared home dotfiles or NFS-backed workspaces.
  --security-opt label=disable
  -v "$PWD:/workspace" -w /workspace
  -v /workspace/.venv
  -v yolo-uv-cache:/home/node/.cache/uv
  -v yolo-claude-config:/home/node/.claude
  -v yolo-bashhistory:/commandhistory
  -e CLAUDE_CONFIG_DIR=/home/node/.claude
)

# SSH agent forwarding — use whatever ssh set up on the host.
if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "$SSH_AUTH_SOCK" ]; then
  args+=(-v "$SSH_AUTH_SOCK:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent)
fi

# --- GPU passthrough (auto-detect) ---------------------------------------
gpu_mode="none"
if command -v nvidia-ctk >/dev/null 2>&1 && \
   { [ -d /etc/cdi ] || [ -d /var/run/cdi ]; } && \
   ls /etc/cdi/nvidia*.yaml /var/run/cdi/nvidia*.yaml >/dev/null 2>&1; then
  args+=(--device nvidia.com/gpu=all)
  gpu_mode="cdi"
elif [ -e /dev/nvidiactl ]; then
  # Raw device + driver lib bind mount (no nvidia-container-toolkit on host).
  # Passes only the nvidia* devices visible to this process — under an
  # interactive SLURM session, cgroups limit visibility to the allocated GPU.
  for dev in /dev/nvidiactl /dev/nvidia-uvm /dev/nvidia-uvm-tools /dev/nvidia-modeset; do
    [ -e "$dev" ] && args+=(--device "$dev")
  done
  for dev in /dev/nvidia[0-9]*; do
    [ -e "$dev" ] && args+=(--device "$dev")
  done
  # Driver userspace libs — the container's CUDA runtime dlopens these.
  # nvidia-smi is handy for sanity checks.
  for lib in /usr/lib64/libcuda.so* /usr/lib64/libnvidia-ml.so* \
             /usr/lib64/libnvidia-ptxjitcompiler.so* /usr/lib64/libnvidia-nvvm.so*; do
    [ -e "$lib" ] && args+=(-v "$lib:$lib:ro")
  done
  [ -x /usr/bin/nvidia-smi ] && args+=(-v /usr/bin/nvidia-smi:/usr/bin/nvidia-smi:ro)
  gpu_mode="devices"
fi

# Host config read-only (CLAUDE.md, settings, skills, statusline, starship, netrc, gitconfig).
# Each mount is conditional on the host file existing — missing files are silently skipped.
add_ro() { [ -e "$1" ] && args+=(-v "$1:$2:ro"); }
add_ro_first() {
  # First candidate that exists wins; lets us prefer standard paths and fall back to dotfiles layouts.
  local target="$1"; shift
  for candidate in "$@"; do
    if [ -e "$candidate" ]; then
      args+=(-v "$candidate:$target:ro")
      return
    fi
  done
}
add_ro "$HOME/.claude/CLAUDE.md"             /home/node/.claude/CLAUDE.md
add_ro "$HOME/.claude/settings.json"         /home/node/.claude/settings.json
add_ro "$HOME/.claude/settings.local.json"   /home/node/.claude/settings.local.json
add_ro "$HOME/.claude/skills"                /home/node/.claude/skills
add_ro "$HOME/.agents/skills"                /home/node/.agents/skills
add_ro "$HOME/.claude/statusline-command.sh" /home/node/.claude/statusline-command.sh
add_ro "$HOME/.claude.json"                  /yolo/host-claude.json
add_ro_first                                 /home/node/.config/starship.toml \
  "$HOME/.config/starship.toml" \
  "$HOME/.dotfiles/starship.toml"
add_ro "$HOME/.netrc"                        /home/node/.netrc
add_ro "$HOME/.gitconfig"                    /home/node/.gitconfig

# Forward WANDB_API_KEY so the wandb HTTP MCP can authenticate
if [ -n "${WANDB_API_KEY:-}" ]; then
  args+=(-e WANDB_API_KEY)
fi

# Forward ANTHROPIC_API_KEY if set (optional — otherwise use `claude` interactive login)
if [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  args+=(-e ANTHROPIC_API_KEY)
fi

echo "yolo: engine=$ENGINE gpu=$gpu_mode workspace=$PWD" >&2

exec "$ENGINE" run "${args[@]}" "$IMAGE" \
  bash -lc '
    set -e

    # Sync mcpServers from host ~/.claude.json into container config.
    # CLAUDE_CONFIG_DIR redirects where the CLI reads/writes .claude.json, so
    # we must honor it — default $HOME/.claude.json is wrong when the env var is set.
    if [ -f /yolo/host-claude.json ]; then
      target="${CLAUDE_CONFIG_DIR:-$HOME}/.claude.json"
      host_mcps=$(jq -c ".mcpServers // {}" /yolo/host-claude.json 2>/dev/null || echo "{}")
      if [ -f "$target" ]; then
        jq --argjson m "$host_mcps" ".mcpServers = \$m" "$target" > "$target.tmp" && mv "$target.tmp" "$target"
      else
        echo "{\"mcpServers\": $host_mcps}" | jq . > "$target"
      fi
      count=$(echo "$host_mcps" | jq "keys | length")
      echo "yolo: synced $count MCP server(s) from host -> $target"
    fi

    # Python project: sync deps into container-local .venv (anonymous volume)
    if [ -f pyproject.toml ] && [ ! -x .venv/bin/python ]; then
      echo "yolo: running uv sync..."
      uv sync
    fi

    exec zsh
  '
